############################
# Online-IDE Beispielkonfiguration
############################

# Basis-Name für Team-VMs
instance_name = "online-ide"

# Name des Packer-Images (muss vorher gebaut werden)
image_name = "online-ide-v1"

# OpenStack Flavor
flavor = "gp1.small"

# Floating IPs aktivieren (für externen Zugriff erforderlich)
enable_floating_ip = true

# SSH-Zugriff einschränken (empfohlen: eigene IP)
ssh_cidr = "0.0.0.0/0"  # In Produktion: "your.ip.address/32"

# ICMP (Ping) erlauben
allow_icmp = true

# OpenStack Key Pair (für SSH-Admin-Zugriff)
key_pair = "your-keypair-name"

# Internes Netzwerk UUID
network_uuid = "34a00b87-57ce-42c4-8e1b-9ea8a657ec2e"

# External Network für Floating IPs
floating_ip_pool = "DHBW"

############################
# USER MANAGEMENT (CONTRACT)
############################

# Teams mit User-E-Mails (vom Professor übermittelt)
users = {
  "team-a" = [
    { email = "alice.smith@example.com" },
    { email = "bob.miller@example.com" }
  ],
  "team-b" = [
    { email = "carol.jones@example.com" },
    { email = "david.brown@example.com" }
  ],
  "team-c" = [
    { email = "eve.wilson@example.com" }
  ]
}

# Optionale Metadata
metadata = {
  project = "online-ide"
  course  = "Cloud Computing"
}
